// Prisma schema — SQLite in dev, PostgreSQL-compatible (swap provider + URL only)
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Source {
  id        String    @id @default(cuid())
  name      String
  url       String    @unique
  category  String
  language  String    @default("en")
  isActive  Boolean   @default(true)
  articles  Article[]
  createdAt DateTime  @default(now())
}

model Article {
  id          String   @id @default(cuid())
  title       String
  url         String   @unique
  summary     String?
  imageUrl    String?
  publishedAt DateTime
  source      Source   @relation(fields: [sourceId], references: [id])
  sourceId    String
  category    String
  isPositive  Boolean  @default(true)
  flaggedAt   DateTime?
  curatedAt   DateTime?
  createdAt   DateTime @default(now())
}

model LearnedKeyword {
  id       String  @id @default(cuid())
  keyword  String  @unique
  language String  @default("en")
  hits     Int     @default(1)
  active   Boolean @default(false)
}
