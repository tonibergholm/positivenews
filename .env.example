# Required: secret token for the /api/ingest endpoint
# Generate with: openssl rand -hex 32
INGEST_SECRET=replace-with-a-random-secret

# Database connection URL
DATABASE_URL=postgresql://user:password@localhost:5432/positivenews

# Redis connection URL (optional; defaults to local Redis on 6379)
REDIS_URL=redis://127.0.0.1:6379
