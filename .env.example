# Required: secret token for the /api/ingest endpoint
# Generate with: openssl rand -hex 32
INGEST_SECRET=replace-with-a-random-secret

# Database connection URL
DATABASE_URL=postgresql://user:password@localhost:5432/positivenews

# Redis connection URL (optional; defaults to local Redis on 6379)
REDIS_URL=redis://127.0.0.1:6379

# Admin panel auth (NextAuth v5)
# AUTH_SECRET is required in production — generate with: openssl rand -hex 32
AUTH_SECRET=replace-with-a-random-secret
# URL of the site including basePath, used by NextAuth for callbacks
AUTH_URL=http://localhost:3001/news
# Admin login credentials
ADMIN_EMAIL=admin@example.com
# Generate hash with: node -e "require('bcryptjs').hash('your-password',12).then(console.log)"
ADMIN_PASSWORD_HASH=replace-with-bcrypt-hash

# Adaptive filtering thresholds (these are the defaults — only set to override)
KEYWORD_MIN_HITS=5
KEYWORD_MIN_IPS=2
KEYWORD_STALE_DAYS=30
KEYWORD_AUTO_ACTIVATE_DAYS=7
